NODE_ENV=development
PORT=3001
HOST=0.0.0.0
LOG_LEVEL=info

# Prisma — Connection Pooling (pgBouncer) para queries em runtime
DATABASE_URL="postgresql://postgres.SEU_PROJECT_REF:[SUA-SENHA]@aws-1-us-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Prisma — Conexão direta para migrations
DIRECT_URL="postgresql://postgres.SEU_PROJECT_REF:[SUA-SENHA]@aws-1-us-east-1.pooler.supabase.com:5432/postgres"

# Supabase — Auth e Storage (service role, NUNCA expor ao frontend)
SUPABASE_URL=https://SEU_PROJECT_REF.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJ...
SUPABASE_ANON_KEY=eyJ...

# CORS — origens separadas por vírgula
CORS_ORIGINS=http://localhost:5173

# Storage
SUPABASE_STORAGE_BUCKET=character-portraits
MAX_IMAGE_SIZE_MB=5
