generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Character {
  id              String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId          String   @map("user_id") @db.Uuid
  name            String
  race            String   @default("")
  concept         String   @default("")
  quote           String   @default("")
  imageUrl        String?  @map("image_url")
  level           Int      @default(0)
  attributes      Json     @default("{\"fisico\":1,\"destreza\":1,\"intelecto\":1,\"influencia\":1}")
  skills          Json     @default("{}")
  talents         String[]
  hp              Int      @default(15)
  sanidade        Int      @default(15)
  currentHp       Int?     @map("current_hp")
  currentSanidade Int?     @map("current_sanidade")
  afinidade       String   @default("")
  antitese        String   @default("")
  entropia        Int      @default(0)
  runas           String[]
  traumas         String[]
  antecedentes    String[]
  historia        String?
  isPublic        Boolean  @default(false) @map("is_public")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  inventoryBags     InventoryBag[]
  inventoryItems    InventoryItem[]
  states            CharacterState[]
  campaignCharacter CampaignCharacter?
  mapTokens         MapToken[]

  @@map("characters")
}

model InventoryBag {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId String   @map("character_id") @db.Uuid
  name        String
  slots       Int      @default(4)
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  character Character      @relation(fields: [characterId], references: [id], onDelete: Cascade)
  items     InventoryItem[]

  @@map("inventory_bags")
}

model InventoryItem {
  id                 String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId        String   @map("character_id") @db.Uuid
  bagId              String?  @map("bag_id") @db.Uuid
  name               String
  description        String   @default("")
  weight             String   @default("nulo")
  isEquipment        Boolean  @default(false) @map("is_equipment")
  maxDurability      Int?     @map("max_durability")
  currentDurability  Int?     @map("current_durability")
  imageUrl           String?  @map("image_url")
  catalogImage       String?  @map("catalog_image")
  fromCatalog        Boolean  @default(false) @map("from_catalog")
  catalogSubcategory String?  @map("catalog_subcategory")
  catalogTier        String?  @map("catalog_tier")
  damage             String?
  effects            String[]
  sortOrder          Int      @default(0) @map("sort_order")
  createdAt          DateTime @default(now()) @map("created_at")
  updatedAt          DateTime @updatedAt @map("updated_at")

  character Character     @relation(fields: [characterId], references: [id], onDelete: Cascade)
  bag       InventoryBag? @relation(fields: [bagId], references: [id], onDelete: SetNull)

  @@map("inventory_items")
}

model Campaign {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  gmUserId    String   @map("gm_user_id") @db.Uuid
  title       String
  description String   @default("")
  imageUrl    String?  @map("image_url")
  inviteCode  String   @unique @map("invite_code")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  characters CampaignCharacter[]
  maps       Map[]

  @@map("campaigns")
}

model CampaignCharacter {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId  String   @map("campaign_id") @db.Uuid
  characterId String   @unique @map("character_id") @db.Uuid
  role        String   @default("player")
  joinedAt    DateTime @default(now()) @map("joined_at")

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@map("campaign_characters")
}

model Map {
  id                  String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  campaignId          String   @map("campaign_id") @db.Uuid
  title               String
  isActive            Boolean  @default(false) @map("is_active")
  gridEnabled         Boolean  @default(false) @map("grid_enabled")
  gridSize            Int      @default(64) @map("grid_size")
  visionUnified       Boolean  @default(true) @map("vision_unified")
  defaultVisionRadius Int      @default(150) @map("default_vision_radius")
  fogEnabled          Boolean  @default(false) @map("fog_enabled")
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  campaign Campaign   @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  layers   MapLayer[]
  tokens   MapToken[]
  walls    MapWall[]

  @@map("maps")
}

model MapLayer {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mapId      String   @map("map_id") @db.Uuid
  name       String
  orderIndex Int      @default(0) @map("order_index")
  imageUrl    String   @map("image_url")
  isActive    Boolean  @default(false) @map("is_active")
  fogRevealed Json     @default("[]")  @map("fog_revealed")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  map    Map        @relation(fields: [mapId], references: [id], onDelete: Cascade)
  tokens MapToken[]
  walls  MapWall[]

  @@map("map_layers")
}

model MapWall {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mapId     String   @map("map_id") @db.Uuid
  layerId   String   @map("layer_id") @db.Uuid
  points    Json
  createdAt DateTime @default(now()) @map("created_at")

  map   Map      @relation(fields: [mapId], references: [id], onDelete: Cascade)
  layer MapLayer @relation(fields: [layerId], references: [id], onDelete: Cascade)

  @@map("map_walls")
}

model MapToken {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  mapId        String   @map("map_id") @db.Uuid
  layerId      String   @map("layer_id") @db.Uuid
  characterId  String   @map("character_id") @db.Uuid
  x            Float    @default(0)
  y            Float    @default(0)
  visionRadius Int?     @map("vision_radius")
  isVisible    Boolean  @default(true) @map("is_visible")
  size         Float    @default(1)
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  map       Map       @relation(fields: [mapId], references: [id], onDelete: Cascade)
  layer     MapLayer  @relation(fields: [layerId], references: [id], onDelete: Cascade)
  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@map("map_tokens")
}

model CharacterState {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  characterId      String   @map("character_id") @db.Uuid
  userId           String   @map("user_id") @db.Uuid
  peChecks         Json     @default("{}") @map("pe_checks")
  skillModifiers   Json     @default("{}") @map("skill_modifiers")
  defenseModifiers Json     @default("{\"daBase\":1,\"daBonus\":0,\"dpBonus\":0}") @map("defense_modifiers")
  diceLog          Json     @default("[]") @map("dice_log")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  character Character @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@unique([characterId, userId])
  @@map("character_state")
}
